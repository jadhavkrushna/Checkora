# Django Secret Key
SECRET_KEY=your-secret-key-here

# Debug Mode (True/False)
DEBUG=True

# Database Connection String
# For local SQLite: sqlite:///db.sqlite3
# For Postgres: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration for OTP
# Local development prints OTP emails in the runserver terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Optional real email setup for later production-like testing.
# Gmail requires a 16-character Google App Password.
# Do not use your normal Gmail password here.
# EMAIL_HOST_USER=yourgmail@gmail.com
# EMAIL_HOST_PASSWORD=your_google_app_password
# DEFAULT_FROM_EMAIL=yourgmail@gmail.com
